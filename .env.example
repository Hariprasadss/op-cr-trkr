# Copy to .env for local dev (netlify dev loads it). Never commit the real .env.
# In production, set these in Netlify: Site settings -> Environment variables.

LEADMAGIC_API_KEY=your-leadmagic-key
ICYPEAS_API_KEY=your-icypeas-api-key
ICYPEAS_USER_EMAIL=you@example.com
BOUNCEBAN_API_KEY=your-bounceban-key
DISCOLIKE_API_KEY=your-discolike-key
AIARK_API_KEY=your-ai-ark-token
ZEROBOUNCE_API_KEY=your-zerobounce-key
